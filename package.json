{
  "name": "enterprise-agent-hub",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "pnpm -r --if-present test && node --test test/*.test.js",
    "test:python": "node scripts/run-python-tests.js",
    "lint": "node scripts/lint-workspace.js",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:python && pnpm build && pnpm migrate:postgres && pnpm migrate:sqlite",
    "verify:production": "node scripts/verify-production-assets.js",
    "verify:production:runtime": "node scripts/verify-production-runtime.js",
    "migrate:postgres": "node packages/migrations/src/run-postgres-migrations.js --dry-run",
    "migrate:sqlite": "node packages/migrations/src/run-sqlite-migrations.js --dry-run"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "typescript": "6.0.2"
  }
}
