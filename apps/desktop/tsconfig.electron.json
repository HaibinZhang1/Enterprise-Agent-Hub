{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node", "electron"],
    "rootDir": "src-electron",
    "outDir": "dist-electron",
    "noEmit": false,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src-electron/**/*.ts"]
}
