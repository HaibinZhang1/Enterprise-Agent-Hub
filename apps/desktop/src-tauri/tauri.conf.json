{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EnterpriseAgentHub",
  "version": "0.1.0",
  "identifier": "com.enterpriseagenthub.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Enterprise Agent Hub",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.svg"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      }
    }
  }
}
