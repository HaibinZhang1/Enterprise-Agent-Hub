{
  "name": "@enterprise-agent-hub/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run build --workspace @enterprise-agent-hub/shared-contracts && tsc --noEmit && vite build",
    "electron:typecheck": "tsc -p tsconfig.electron.json --noEmit",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:compile && electron dist-electron/main.js",
    "electron:build": "npm run electron:package",
    "electron:package": "npm run build && npm run electron:compile && electron-builder --dir",
    "electron:build:windows": "npm run build && npm run electron:compile && electron-builder --win nsis --x64",
    "electron:smoke": "npm run electron:typecheck && node --experimental-strip-types --experimental-specifier-resolution=node --test test/electron-*.test.ts",
    "typecheck": "npm run build --workspace @enterprise-agent-hub/shared-contracts && tsc --noEmit && npm run electron:typecheck",
    "lint": "node ./scripts/p1-ui-lint.mjs",
    "test": "npm run typecheck && node --experimental-strip-types --experimental-specifier-resolution=node --test test/*.test.ts"
  },
  "dependencies": {
    "@enterprise-agent-hub/shared-contracts": "0.1.0",
    "@vitejs/plugin-react": "6.0.1",
    "vite": "8.0.8",
    "typescript": "5.9.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "lucide-react": "1.8.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/node": "^25.6.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.enterpriseagenthub.desktop",
    "productName": "Enterprise Agent Hub",
    "artifactName": "Enterprise Agent Hub-${version}-${arch}.${ext}",
    "directories": {
      "output": "release/electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "executableName": "Enterprise Agent Hub"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Enterprise Agent Hub",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dir"
      ]
    },
    "linux": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.png"
    }
  }
}
