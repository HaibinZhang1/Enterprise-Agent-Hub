{
  "schemaVersion": 1,
  "policyId": "electron-security-policy",
  "description": "Static policy for the Electron shell security boundary. Non-strict mode reports missing Electron files as pending during parallel migration; strict mode fails until files prove each guard.",
  "requiredFiles": {
    "main": "apps/desktop/src-electron/main.ts",
    "preload": "apps/desktop/src-electron/preload.ts",
    "ipcContract": "apps/desktop/src-electron/ipcContract.ts",
    "security": "apps/desktop/src-electron/security.ts"
  },
  "mainRequiredPatterns": [
    "contextIsolation\\s*:\\s*true",
    "nodeIntegration\\s*:\\s*false",
    "sandbox\\s*:\\s*true",
    "webSecurity\\s*:\\s*true",
    "setWindowOpenHandler\\s*\\(",
    "will-navigate",
    "setPermissionRequestHandler\\s*\\(",
    "Content-Security-Policy|csp"
  ],
  "preloadRequiredPatterns": [
    "contextBridge\\.exposeInMainWorld\\s*\\(",
    "desktopBridge",
    "DESKTOP_IPC_CHANNELS",
    "assertLocalCommandName"
  ],
  "preloadForbiddenPatterns": [
    "exposeInMainWorld\\s*\\([^)]*ipcRenderer",
    "exposeInMainWorld\\s*\\([^)]*ipcMain",
    "exposeInMainWorld\\s*\\([^)]*child_process",
    "exposeInMainWorld\\s*\\([^)]*\\bfs\\b",
    "exposeInMainWorld\\s*\\([^)]*\\bprocess\\b",
    "\\bsend\\s*:\\s*ipcRenderer\\.send",
    "\\binvoke\\s*:\\s*ipcRenderer\\.invoke",
    "\\binvoke\\s*:\\s*async\\s*<"
  ],
  "requiredControls": [
    "contextIsolation true",
    "nodeIntegration false",
    "sandbox true",
    "webSecurity true explicitly set in BrowserWindow options",
    "senderFrame origin validation for every IPC handler",
    "static IPC channel allowlist",
    "no raw ipcRenderer/ipcMain/fs/process/child_process exposure",
    "no generic preload invoke dispatcher exposed to renderer; prefer explicit methods or generated per-command wrappers",
    "navigation and new-window denial by default",
    "permission request denial by default",
    "packaged renderer CSP"
  ],
  "ipcContractRequiredPatterns": [
    "DESKTOP_IPC_CHANNELS",
    "LOCAL_COMMAND_NAMES",
    "assertLocalCommandName",
    "assertWindowControlAction",
    "desktop:local-command",
    "desktop:window-control",
    "desktop:open-external-url"
  ],
  "securityRequiredPatterns": [
    "assertAllowedSenderURL",
    "isAllowedRendererURL",
    "senderFrame|getURL",
    "127\\.0\\.0\\.1",
    "file:",
    "isSafeExternalURL",
    "buildRendererContentSecurityPolicy"
  ]
}
