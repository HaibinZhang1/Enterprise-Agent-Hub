{
  "schemaVersion": 1,
  "policyId": "rust-exception-gate",
  "migrationPhase": "electron-runtime-complete",
  "description": "Rust may remain after the Electron migration only as a documented non-Electron helper. The final migration retains no Rust helpers and no legacy src-tauri runtime.",
  "allowedHelperRoots": [
    "apps/desktop/native-helpers/**",
    "packages/*/native-helpers/**"
  ],
  "approvedCriteria": [
    "path-traversal-or-distribution-safety-would-weaken-in-node",
    "sqlite-migration-parity-not-provable-quickly",
    "hashing-or-authenticode-verification-more-reliable-in-helper",
    "package-lifecycle-drift-covered-by-existing-rust-tests-only"
  ],
  "requiredExceptionFields": [
    "id",
    "capability",
    "decision",
    "status",
    "owner",
    "helperRoot",
    "rationale",
    "criteria",
    "parityTests",
    "packagingCheck",
    "ipcErrorMapping",
    "migrationMapReference"
  ],
  "disallowedPathFragments": [
    "src-tauri"
  ],
  "disallowedCratePatterns": [
    "^tauri$",
    "^tauri-build$",
    "^tauri-plugin",
    "^tauri-utils$",
    "^tauri-runtime"
  ],
  "disallowedContentPatterns": [
    "window\\.__TAURI__",
    "tauri::",
    "tauri_build::",
    "tauri_plugin",
    "@tauri-apps/"
  ],
  "exceptions": [],
  "transitionalLegacyRustBlockers": []
}
