POSTGRES_USER=enterprise_agent_hub
POSTGRES_PASSWORD=change_me
POSTGRES_DB=enterprise_agent_hub
DATABASE_URL=postgresql://enterprise_agent_hub:change_me@postgres:5432/enterprise_agent_hub
PUBLIC_HTTP_PORT=8080
# Optional operator-facing URL used by production runtime verification and Desktop clients.
# Set one of these to a LAN URL such as http://10.0.0.15:8080 for intranet proof.
INTRANET_BASE_URL=
PRODUCTION_BASE_URL=
NGINX_IMAGE=nginx:1.29-alpine
POSTGRES_IMAGE=postgres:17-alpine
NODE_RUNTIME_IMAGE=node:24-alpine
API_BASE_IMAGE=node:24-alpine
API_HAS_POSTGRES_CLIENT=0
API_OFFLINE_WORKSPACE=0
SKIP_MIGRATIONS=0
PNPM_REGISTRY_URL=https://registry.npmjs.org
